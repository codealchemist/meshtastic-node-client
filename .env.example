# Select which broker to use: public or private
MQTT_MODE=private

# Public MQTT broker (mqtt.meshtastic.org)
# Note: meshdev/large4cats has read-only ACL — /2/e/ publishes are silently dropped.
# Useful for monitoring the mesh; cannot inject packets into the device.
PUBLIC_MQTT_BROKER=mqtts://mqtt.meshtastic.org:8883
PUBLIC_MQTT_USERNAME=meshdev
PUBLIC_MQTT_PASSWORD=large4cats

# Private MQTT broker (local Aedes — run: npm run broker)
# Full read/write: packets reach the Heltec device.
PRIVATE_MQTT_BROKER=mqtt://localhost:1883
PRIVATE_MQTT_USERNAME=
PRIVATE_MQTT_PASSWORD=

# Meshtastic channel
MQTT_ROOT_TOPIC=msh/US
CHANNEL_NAME=LongFast
CHANNEL_PSK=

# This node's identity
# NODE_ID: 8-char hex string (without the ! prefix), e.g. abcdef01
NODE_ID=abcdef01
NODE_LONG_NAME=My Node
NODE_SHORT_NAME=MYN
# Hardware model shown in the app. 0=UNSET (rabbit icon), 255=PRIVATE_HW.
# Full list: github.com/meshtastic/protobufs/blob/master/meshtastic/mesh.proto (HardwareModel)
NODE_HW_MODEL=0

# Deduplicate packets seen within this window (ms). 0 = disabled.
# The same packet can arrive via multiple gateways or both /2/e/ and /2/json/ paths.
DEDUP_WINDOW_MS=30000
